<Window x:Class="TaskManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager.UI.ViewModels"
        Title="Task Manager"
        Height="600"
        Width="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Input -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- List -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- INPUT SECTION -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">

            <TextBlock Text="Add New Task"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Title:" Width="100"/>
                <TextBox Width="300"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Description:" Width="100"/>
                <TextBox Width="300"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Priority:" Width="100"/>
                <ComboBox Width="150"
              ItemsSource="{Binding Priorities}"
              SelectedItem="{Binding Priority}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Due Date:" Width="100"/>
                <DatePicker SelectedDate="{Binding DueDate}"/>
            </StackPanel>

            <Button Content="Add Task"
                    Width="120"
                    Height="35"
                    Margin="0,10,0,0"
                    Command="{Binding AddTaskCommand}"/>
        </StackPanel>

        <!-- TASK LIST HEADER -->
        <TextBlock Grid.Row="1"
                   Text="Tasks"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,10"/>

        <!-- TASK LIST -->
        <Border Grid.Row="2"
        Margin="0,5"
        BorderBrush="LightGray"
        BorderThickness="1"
        Padding="5">
            <ListView Grid.Row="2"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  SelectionMode="Single">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Title"
                                    DisplayMemberBinding="{Binding Title}"
                                    Width="200"/>

                        <GridViewColumn Header="Priority"
                                    DisplayMemberBinding="{Binding Priority}"
                                    Width="100"/>

                        <GridViewColumn Header="Status"
                                    DisplayMemberBinding="{Binding Status}"
                                    Width="120"/>

                        <GridViewColumn Header="Due Date"
                                    DisplayMemberBinding="{Binding DueDate}"
                                    Width="150"/>

                    </GridView>
                </ListView.View>

            </ListView>
        </Border>

        <StackPanel Grid.Row="3"  Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10,0,0">

            <Button Content="Complete"
            Width="100"
            Margin="5"
            Command="{Binding CompleteTaskCommand}" />

            <Button Content="Reopen"
            Width="100"
            Margin="5"
            Command="{Binding ReopenTaskCommand}" />

            <Button Content="Delete"
            Width="100"
            Margin="5"
            Command="{Binding DeleteTaskCommand}" />
        </StackPanel>

    </Grid>
</Window>